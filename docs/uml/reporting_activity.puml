@startuml
title UML Activity - TG Build Bot Online Polling Flow (Pilot)

start

partition PollingProcess {
  :Log event polling_started;
}

partition User {
  :Open chat with bot;
  :Press /start (first time);
}

partition BotOnline {
  :Send welcome message with "Report Progress" button;
}

partition User {
  :Press "Report Progress";
}

partition BotOnline {
  :Send input instruction message;
}

partition User {
  :Send free-form progress message;
}

partition Telegram {
  :Receive update (Polling);
}

partition BotOnline {
  :Log event message_received;
  :Preprocess text (trim, normalize spaces);
  :Build TelegramMessageMeta;
  :Load dictionaries from text files;
  :Build Gemini prompt;
  :Call Gemini via google-genai SDK (timeout 30 sec);
}

if (Gemini call successful?) then (yes)
  partition BotOnline {
    :Log event llm_response_received;
    :Validate JSON schema + dictionary constraints;
  }

  if (JSON valid?) then (yes)
    partition BotOnline {
      :Log event json_validation_passed;
      :Map structured fields from JSON;
      :Set status = PROCESSED;
    }
  else (no)
    partition BotOnline {
      :Log event json_validation_failed;
      :Fallback mapper - full raw LLM response in comment;
      :Set status = PROCESSED_WITH_FALLBACK;
    }
  endif

  partition GoogleSheets {
    :Append row to data_facts;
  }

  if (Sheets write successful?) then (yes)
    partition BotOnline {
      :Log event sheets_write_success;
      :Send immediate confirmation;
    }
    stop
  else (no)
    partition BotOnline {
      :Log event classification_failed;
      :Send processing error;
    }
    stop
  endif

else (no)
  if (Timeout?) then (yes)
    partition BotOnline {
      :Log event llm_timeout;
      :Build QueueTask;
      :Enqueue message to queue repository;
    }

    if (Enqueue successful?) then (yes)
      partition BotOnline {
        :Log event queue_enqueued;
        :Send queued notice;
      }
      stop
    else (no)
      partition BotOnline {
        :Log event queue_enqueue_failed;
        :Send processing error;
      }
      stop
    endif
  else (error)
    partition BotOnline {
      :Log event classification_failed;
      :Send processing error;
    }
    stop
  endif
endif

note right
  Queue worker flow is documented separately in:
  docs/uml/reporting_queue_worker_activity.puml

  Structured logging contract:
  docs/logging/logging_spec.md
end note

@enduml
