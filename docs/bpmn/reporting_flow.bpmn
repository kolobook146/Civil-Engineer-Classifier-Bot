<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_ConstructionReportBot"
                  targetNamespace="https://example.local/bpmn/construction-report-bot">
  <bpmn:process id="Process_ConstructionReportBot" name="Construction Report Telegram Bot (Pilot)" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Main">
      <bpmn:lane id="Lane_User" name="User">
        <bpmn:flowNodeRef>Start_OpenChat</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>User_OpenChat</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>User_PressStart</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>User_PressReport</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>User_SendFreeText</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Telegram" name="Telegram">
        <bpmn:flowNodeRef>Telegram_ReceivePolling</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Bot" name="Bot Backend">
        <bpmn:flowNodeRef>Bot_SendWelcome</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Bot_SendInputInstruction</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Bot_PreprocessText</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Bot_LoadDictionaries</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Bot_BuildLLMRequest</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Bot_CallLLM_30s</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_LLMRepliedIn30s</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Bot_ValidateJSONSchema</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_JSONValid_Immediate</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Bot_MapValidPayload_Immediate</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Bot_MapFallbackPayload_Immediate</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Bot_SendImmediateConfirmation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Bot_EnqueueMessage</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Bot_SendQueueNotice</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Queue_MessageReady</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Queue_LoadDictionaries</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Queue_BuildLLMRequest</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Queue_CallLLM</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Queue_ValidateJSONSchema</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_JSONValid_Queue</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Queue_MapValidPayload</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Queue_MapFallbackPayload</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Bot_SendPostFactumNotification</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Sheets" name="Google Sheets">
        <bpmn:flowNodeRef>Sheets_WriteDataFacts_Immediate</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Sheets_WriteDataFacts_Queue</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_ImmediateDone</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_QueuedDone</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <bpmn:startEvent id="Start_OpenChat" name="User opens bot chat"/>
    <bpmn:userTask id="User_OpenChat" name="Open chat with bot"/>
    <bpmn:userTask id="User_PressStart" name="Press /start (first time)"/>
    <bpmn:serviceTask id="Bot_SendWelcome" name="Send welcome message"/>
    <bpmn:userTask id="User_PressReport" name="Press button: Report Progress"/>
    <bpmn:serviceTask id="Bot_SendInputInstruction" name="Send free-form input instruction"/>
    <bpmn:userTask id="User_SendFreeText" name="Send free-form work report"/>
    <bpmn:serviceTask id="Telegram_ReceivePolling" name="Receive Update (Polling)"/>

    <bpmn:serviceTask id="Bot_PreprocessText" name="Preprocess text: trim + normalize spaces + log message_received"/>
    <bpmn:serviceTask id="Bot_LoadDictionaries" name="Load dictionaries from text files (project folder)"/>
    <bpmn:serviceTask id="Bot_BuildLLMRequest" name="Build Gemini request via google-genai SDK: dictionaries + full raw_text + stage/function definitions"/>
    <bpmn:serviceTask id="Bot_CallLLM_30s" name="Call Gemini via google-genai SDK (timeout: 30 seconds) + log llm_response_received/llm_timeout"/>
    <bpmn:exclusiveGateway id="Gateway_LLMRepliedIn30s" name="LLM replied in 30 seconds?"/>

    <bpmn:serviceTask id="Bot_ValidateJSONSchema" name="Validate strict JSON schema (single value or null for work_type/stage/function) + log json_validation_passed/failed"/>
    <bpmn:exclusiveGateway id="Gateway_JSONValid_Immediate" name="JSON valid?"/>
    <bpmn:serviceTask id="Bot_MapValidPayload_Immediate" name="Build payload from valid JSON (status=PROCESSED)"/>
    <bpmn:serviceTask id="Bot_MapFallbackPayload_Immediate" name="Fallback: put full LLM response into comment (status=PROCESSED_WITH_FALLBACK)"/>
    <bpmn:serviceTask id="Sheets_WriteDataFacts_Immediate" name="Write to data_facts: parsed fields + raw_text + audit fields + log sheets_write_success/failed"/>
    <bpmn:serviceTask id="Bot_SendImmediateConfirmation" name="Notify user: recorded data: {JSON}"/>

    <bpmn:serviceTask id="Bot_EnqueueMessage" name="Put message into queue (status=QUEUED) + log queue_enqueued"/>
    <bpmn:serviceTask id="Bot_SendQueueNotice" name="Notify user: LLM busy, message queued"/>
    <bpmn:intermediateCatchEvent id="Queue_MessageReady" name="Queue worker picks message + log queue_dequeued">
      <bpmn:messageEventDefinition id="MessageEvent_QueueReady"/>
    </bpmn:intermediateCatchEvent>

    <bpmn:serviceTask id="Queue_LoadDictionaries" name="Queue worker: load dictionaries from text files"/>
    <bpmn:serviceTask id="Queue_BuildLLMRequest" name="Queue worker: build Gemini request via google-genai SDK with raw_text + stage/function definitions"/>
    <bpmn:serviceTask id="Queue_CallLLM" name="Queue worker: call Gemini via google-genai SDK"/>
    <bpmn:serviceTask id="Queue_ValidateJSONSchema" name="Queue worker: validate strict JSON schema"/>
    <bpmn:exclusiveGateway id="Gateway_JSONValid_Queue" name="JSON valid (queue)?"/>
    <bpmn:serviceTask id="Queue_MapValidPayload" name="Queue worker: build payload (status=PROCESSED_FROM_QUEUE)"/>
    <bpmn:serviceTask id="Queue_MapFallbackPayload" name="Queue fallback: full LLM response into comment (status=PROCESSED_FROM_QUEUE_FALLBACK)"/>
    <bpmn:serviceTask id="Sheets_WriteDataFacts_Queue" name="Write to data_facts: parsed fields + raw_text + audit fields + log sheets_write_success/failed"/>
    <bpmn:serviceTask id="Bot_SendPostFactumNotification" name="Post-factum notify user: queued message recorded + log post_factum_notification_sent"/>

    <bpmn:endEvent id="End_ImmediateDone" name="Done (immediate)"/>
    <bpmn:endEvent id="End_QueuedDone" name="Done (after queue)"/>

    <bpmn:sequenceFlow id="Flow_01" sourceRef="Start_OpenChat" targetRef="User_OpenChat"/>
    <bpmn:sequenceFlow id="Flow_02" sourceRef="User_OpenChat" targetRef="User_PressStart"/>
    <bpmn:sequenceFlow id="Flow_03" sourceRef="User_PressStart" targetRef="Bot_SendWelcome"/>
    <bpmn:sequenceFlow id="Flow_04" sourceRef="Bot_SendWelcome" targetRef="User_PressReport"/>
    <bpmn:sequenceFlow id="Flow_05" sourceRef="User_PressReport" targetRef="Bot_SendInputInstruction"/>
    <bpmn:sequenceFlow id="Flow_06" sourceRef="Bot_SendInputInstruction" targetRef="User_SendFreeText"/>
    <bpmn:sequenceFlow id="Flow_07" sourceRef="User_SendFreeText" targetRef="Telegram_ReceivePolling"/>
    <bpmn:sequenceFlow id="Flow_08" sourceRef="Telegram_ReceivePolling" targetRef="Bot_PreprocessText"/>
    <bpmn:sequenceFlow id="Flow_09" sourceRef="Bot_PreprocessText" targetRef="Bot_LoadDictionaries"/>
    <bpmn:sequenceFlow id="Flow_10" sourceRef="Bot_LoadDictionaries" targetRef="Bot_BuildLLMRequest"/>
    <bpmn:sequenceFlow id="Flow_11" sourceRef="Bot_BuildLLMRequest" targetRef="Bot_CallLLM_30s"/>
    <bpmn:sequenceFlow id="Flow_12" sourceRef="Bot_CallLLM_30s" targetRef="Gateway_LLMRepliedIn30s"/>

    <bpmn:sequenceFlow id="Flow_13_yes" sourceRef="Gateway_LLMRepliedIn30s" targetRef="Bot_ValidateJSONSchema" name="Yes"/>
    <bpmn:sequenceFlow id="Flow_13_no" sourceRef="Gateway_LLMRepliedIn30s" targetRef="Bot_EnqueueMessage" name="No"/>

    <bpmn:sequenceFlow id="Flow_14" sourceRef="Bot_ValidateJSONSchema" targetRef="Gateway_JSONValid_Immediate"/>
    <bpmn:sequenceFlow id="Flow_15_yes" sourceRef="Gateway_JSONValid_Immediate" targetRef="Bot_MapValidPayload_Immediate" name="Yes"/>
    <bpmn:sequenceFlow id="Flow_15_no" sourceRef="Gateway_JSONValid_Immediate" targetRef="Bot_MapFallbackPayload_Immediate" name="No"/>
    <bpmn:sequenceFlow id="Flow_16a" sourceRef="Bot_MapValidPayload_Immediate" targetRef="Sheets_WriteDataFacts_Immediate"/>
    <bpmn:sequenceFlow id="Flow_16b" sourceRef="Bot_MapFallbackPayload_Immediate" targetRef="Sheets_WriteDataFacts_Immediate"/>
    <bpmn:sequenceFlow id="Flow_17" sourceRef="Sheets_WriteDataFacts_Immediate" targetRef="Bot_SendImmediateConfirmation"/>
    <bpmn:sequenceFlow id="Flow_18" sourceRef="Bot_SendImmediateConfirmation" targetRef="End_ImmediateDone"/>

    <bpmn:sequenceFlow id="Flow_19" sourceRef="Bot_EnqueueMessage" targetRef="Bot_SendQueueNotice"/>
    <bpmn:sequenceFlow id="Flow_20" sourceRef="Bot_SendQueueNotice" targetRef="Queue_MessageReady"/>
    <bpmn:sequenceFlow id="Flow_21" sourceRef="Queue_MessageReady" targetRef="Queue_LoadDictionaries"/>
    <bpmn:sequenceFlow id="Flow_22" sourceRef="Queue_LoadDictionaries" targetRef="Queue_BuildLLMRequest"/>
    <bpmn:sequenceFlow id="Flow_23" sourceRef="Queue_BuildLLMRequest" targetRef="Queue_CallLLM"/>
    <bpmn:sequenceFlow id="Flow_24" sourceRef="Queue_CallLLM" targetRef="Queue_ValidateJSONSchema"/>
    <bpmn:sequenceFlow id="Flow_25" sourceRef="Queue_ValidateJSONSchema" targetRef="Gateway_JSONValid_Queue"/>
    <bpmn:sequenceFlow id="Flow_26_yes" sourceRef="Gateway_JSONValid_Queue" targetRef="Queue_MapValidPayload" name="Yes"/>
    <bpmn:sequenceFlow id="Flow_26_no" sourceRef="Gateway_JSONValid_Queue" targetRef="Queue_MapFallbackPayload" name="No"/>
    <bpmn:sequenceFlow id="Flow_27a" sourceRef="Queue_MapValidPayload" targetRef="Sheets_WriteDataFacts_Queue"/>
    <bpmn:sequenceFlow id="Flow_27b" sourceRef="Queue_MapFallbackPayload" targetRef="Sheets_WriteDataFacts_Queue"/>
    <bpmn:sequenceFlow id="Flow_28" sourceRef="Sheets_WriteDataFacts_Queue" targetRef="Bot_SendPostFactumNotification"/>
    <bpmn:sequenceFlow id="Flow_29" sourceRef="Bot_SendPostFactumNotification" targetRef="End_QueuedDone"/>

    <bpmn:textAnnotation id="TextAnnotation_PostPilot">
      <bpmn:text>Pilot logging (required): structured JSON logs for message_received, llm_response_received/llm_timeout, json_validation_passed/failed, queue_enqueued/queue_dequeued, sheets_write_success/failed, post_factum_notification_sent. Required fields: timestamp, level, event, component, trace_id, chat_id, user_id, message_id, processing_path, status. Full spec: docs/logging/logging_spec.md. Post-pilot (out of scope here): idempotent writes, retry policy + DLQ, confidence logging, operational monitoring, dictionary schema expansion to code/label/description.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_PostPilot" sourceRef="End_QueuedDone" targetRef="TextAnnotation_PostPilot"/>
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_ConstructionReportBot">
    <bpmndi:BPMNPlane id="BPMNPlane_ConstructionReportBot" bpmnElement="Process_ConstructionReportBot">
      <bpmndi:BPMNShape id="Shape_Lane_User" bpmnElement="Lane_User" isHorizontal="true">
        <dc:Bounds x="120" y="120" width="4440" height="130"/>
      </bpmndi:BPMNShape>
