        <di:waypoint x="1120" y="185"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_07" bpmnElement="Flow_07">
        <di:waypoint x="1240" y="185"/>
        <di:waypoint x="1270" y="185"/>
        <di:waypoint x="1270" y="305"/>
        <di:waypoint x="1300" y="305"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_08" bpmnElement="Flow_08">
        <di:waypoint x="1420" y="305"/>
        <di:waypoint x="1450" y="305"/>
        <di:waypoint x="1450" y="450"/>
        <di:waypoint x="1480" y="450"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_09" bpmnElement="Flow_09">
        <di:waypoint x="1600" y="450"/>
        <di:waypoint x="1660" y="450"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_10" bpmnElement="Flow_10">
        <di:waypoint x="1780" y="450"/>
        <di:waypoint x="1840" y="450"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_11" bpmnElement="Flow_11">
        <di:waypoint x="1960" y="450"/>
        <di:waypoint x="2020" y="450"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_12" bpmnElement="Flow_12">
        <di:waypoint x="2140" y="450"/>
        <di:waypoint x="2200" y="450"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_13_yes" bpmnElement="Flow_13_yes">
        <di:waypoint x="2250" y="450"/>
        <di:waypoint x="2320" y="450"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_13_no" bpmnElement="Flow_13_no">
        <di:waypoint x="2225" y="475"/>
        <di:waypoint x="2225" y="560"/>
        <di:waypoint x="2320" y="560"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_14" bpmnElement="Flow_14">
        <di:waypoint x="2440" y="450"/>
        <di:waypoint x="2500" y="450"/>
