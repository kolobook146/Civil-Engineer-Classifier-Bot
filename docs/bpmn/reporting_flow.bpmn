        <dc:Bounds x="120" y="250" width="4440" height="110"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Lane_Bot" bpmnElement="Lane_Bot" isHorizontal="true">
        <dc:Bounds x="120" y="360" width="4440" height="300"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Lane_Sheets" bpmnElement="Lane_Sheets" isHorizontal="true">
        <dc:Bounds x="120" y="660" width="4440" height="180"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_Start_OpenChat" bpmnElement="Start_OpenChat">
        <dc:Bounds x="160" y="167" width="36" height="36"/>
      </bpmndi:BPMNShape>
