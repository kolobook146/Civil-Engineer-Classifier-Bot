      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Edge_Flow_01" bpmnElement="Flow_01">
        <di:waypoint x="196" y="185"/>
        <di:waypoint x="220" y="185"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_02" bpmnElement="Flow_02">
        <di:waypoint x="340" y="185"/>
        <di:waypoint x="390" y="185"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_03" bpmnElement="Flow_03">
        <di:waypoint x="510" y="185"/>
        <di:waypoint x="550" y="185"/>
        <di:waypoint x="550" y="450"/>
        <di:waypoint x="580" y="450"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_04" bpmnElement="Flow_04">
