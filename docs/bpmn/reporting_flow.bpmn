<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_ConstructionReportBot"
                  targetNamespace="https://example.local/bpmn/construction-report-bot">

  <bpmn:process id="Process_ConstructionReportBot" name="Construction Report Telegram Bot (Pilot, polling + queue worker)" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Main">
      <bpmn:lane id="Lane_User" name="User">
        <bpmn:flowNodeRef>Start_UserOpensChat</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>User_OpenChat</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>User_PressStart</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>User_PressReportProgress</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>User_SendFreeText</bpmn:flowNodeRef>
      </bpmn:lane>

      <bpmn:lane id="Lane_Telegram" name="Telegram">
        <bpmn:flowNodeRef>TG_ReceivePollingUpdate</bpmn:flowNodeRef>
      </bpmn:lane>

      <bpmn:lane id="Lane_Bot" name="Bot Backend (Online Path)">
        <bpmn:flowNodeRef>Bot_SendWelcome</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Bot_SendInputInstruction</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Bot_PreprocessText</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Bot_LoadDictionariesOnline</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Bot_BuildPromptOnline</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Bot_CallGeminiOnline</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_OnlineLlmReplied</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Bot_ValidateJsonOnline</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_OnlineJsonValid</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Bot_MapValidOnline</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Bot_MapFallbackOnline</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Bot_CreateQueueTask</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Bot_EnqueueMessage</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_EnqueueSucceeded</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Bot_SendQueuedNotice</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Bot_SendImmediateConfirmation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Bot_SendProcessingError</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Bot_SendPostFactumNotification</bpmn:flowNodeRef>
      </bpmn:lane>

      <bpmn:lane id="Lane_QueueWorker" name="Queue Worker (Deferred Path)">
        <bpmn:flowNodeRef>Queue_MessageReady</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Queue_PickPendingMessage</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Queue_LoadDictionaries</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Queue_BuildPrompt</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Queue_CallGemini</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_QueueLlmTimeout</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Queue_ValidateJson</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_QueueJsonValid</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Queue_MapValid</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Queue_MapFallback</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Queue_MarkDone</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Queue_RequeueOnTimeout</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Queue_RequeueOnProcessingError</bpmn:flowNodeRef>
      </bpmn:lane>

      <bpmn:lane id="Lane_Sheets" name="Google Sheets">
        <bpmn:flowNodeRef>Sheets_WriteOnline</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_OnlineSheetsWriteSucceeded</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Sheets_WriteQueue</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_QueueSheetsWriteSucceeded</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_OnlineQueued</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_OnlineDone</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_OnlineFailed</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_QueueDeferred</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_QueuedDone</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <bpmn:startEvent id="Start_UserOpensChat" name="User opens bot chat"/>
    <bpmn:userTask id="User_OpenChat" name="Open chat with bot"/>
    <bpmn:userTask id="User_PressStart" name="Press /start (first time)"/>
    <bpmn:serviceTask id="Bot_SendWelcome" name="Send welcome message + button Report Progress"/>
    <bpmn:userTask id="User_PressReportProgress" name="Press button: Report Progress"/>
    <bpmn:serviceTask id="Bot_SendInputInstruction" name="Send free-form input instruction"/>
    <bpmn:userTask id="User_SendFreeText" name="Send free-form progress message"/>
    <bpmn:serviceTask id="TG_ReceivePollingUpdate" name="Receive Update (Polling)"/>

    <bpmn:serviceTask id="Bot_PreprocessText" name="Preprocess text: trim + normalize spaces + log message_received"/>
    <bpmn:serviceTask id="Bot_LoadDictionariesOnline" name="Load dictionaries from text files (work types/stages/functions)"/>
    <bpmn:serviceTask id="Bot_BuildPromptOnline" name="Build Gemini prompt: dictionaries + normalized/raw text"/>
    <bpmn:serviceTask id="Bot_CallGeminiOnline" name="Call Gemini (timeout 30s) + log llm_response_received/llm_timeout"/>
    <bpmn:exclusiveGateway id="Gateway_OnlineLlmReplied" name="Gemini call outcome?"/>

    <bpmn:serviceTask id="Bot_ValidateJsonOnline" name="Validate JSON schema + dictionary constraints"/>
    <bpmn:exclusiveGateway id="Gateway_OnlineJsonValid" name="JSON valid?"/>
    <bpmn:serviceTask id="Bot_MapValidOnline" name="Map valid payload (status=PROCESSED) + log json_validation_passed"/>
    <bpmn:serviceTask id="Bot_MapFallbackOnline" name="Map fallback payload (status=PROCESSED_WITH_FALLBACK) + log json_validation_failed"/>
    <bpmn:serviceTask id="Sheets_WriteOnline" name="Write data_facts: raw_text + classification + audit fields"/>
    <bpmn:exclusiveGateway id="Gateway_OnlineSheetsWriteSucceeded" name="Sheets write succeeded?"/>
    <bpmn:serviceTask id="Bot_SendImmediateConfirmation" name="Notify user: Recorded data + Status"/>

    <bpmn:serviceTask id="Bot_CreateQueueTask" name="Create queue task (raw_text + normalized_text + message metadata)"/>
    <bpmn:serviceTask id="Bot_EnqueueMessage" name="Enqueue message (status=QUEUED) + log queue_enqueued"/>
    <bpmn:exclusiveGateway id="Gateway_EnqueueSucceeded" name="Enqueue succeeded?"/>
    <bpmn:serviceTask id="Bot_SendQueuedNotice" name="Notify user: LLM is busy, message queued"/>
    <bpmn:serviceTask id="Bot_SendProcessingError" name="Notify user: processing failed, please retry"/>

    <bpmn:startEvent id="Queue_MessageReady" name="Queue worker picks pending task (polling tick)">
      <bpmn:messageEventDefinition id="MessageEvent_QueueReady"/>
    </bpmn:startEvent>

    <bpmn:serviceTask id="Queue_PickPendingMessage" name="Pick oldest pending queue item (recover processing->pending on startup)"/>
    <bpmn:serviceTask id="Queue_LoadDictionaries" name="Queue worker: load dictionaries"/>
    <bpmn:serviceTask id="Queue_BuildPrompt" name="Queue worker: build Gemini prompt"/>
    <bpmn:serviceTask id="Queue_CallGemini" name="Queue worker: call Gemini"/>
    <bpmn:exclusiveGateway id="Gateway_QueueLlmTimeout" name="Queue Gemini call outcome?"/>
    <bpmn:serviceTask id="Queue_RequeueOnTimeout" name="Requeue task (reason=llm_timeout) + log queue_enqueued"/>

    <bpmn:serviceTask id="Queue_ValidateJson" name="Queue worker: validate JSON schema + dictionary constraints"/>
    <bpmn:exclusiveGateway id="Gateway_QueueJsonValid" name="Queue JSON valid?"/>
    <bpmn:serviceTask id="Queue_MapValid" name="Map valid payload (status=PROCESSED_FROM_QUEUE)"/>
    <bpmn:serviceTask id="Queue_MapFallback" name="Map fallback payload (status=PROCESSED_FROM_QUEUE_FALLBACK)"/>

    <bpmn:serviceTask id="Sheets_WriteQueue" name="Queue worker: write data_facts"/>
    <bpmn:exclusiveGateway id="Gateway_QueueSheetsWriteSucceeded" name="Queue write succeeded?"/>
    <bpmn:serviceTask id="Queue_MarkDone" name="Mark queue task done (delete from queue)"/>
    <bpmn:serviceTask id="Bot_SendPostFactumNotification" name="Send post-factum notification + log post_factum_notification_sent"/>
    <bpmn:serviceTask id="Queue_RequeueOnProcessingError" name="Requeue task + log queue_processing_failed"/>

    <bpmn:endEvent id="End_OnlineQueued" name="Done (queued for deferred processing)"/>
    <bpmn:endEvent id="End_OnlineDone" name="Done (online)"/>
    <bpmn:endEvent id="End_OnlineFailed" name="Done (online error)"/>
    <bpmn:endEvent id="End_QueueDeferred" name="Done (requeued for later retry)"/>
    <bpmn:endEvent id="End_QueuedDone" name="Done (processed from queue)"/>

    <bpmn:sequenceFlow id="Flow_01" sourceRef="Start_UserOpensChat" targetRef="User_OpenChat"/>
    <bpmn:sequenceFlow id="Flow_02" sourceRef="User_OpenChat" targetRef="User_PressStart"/>
    <bpmn:sequenceFlow id="Flow_03" sourceRef="User_PressStart" targetRef="Bot_SendWelcome"/>
    <bpmn:sequenceFlow id="Flow_04" sourceRef="Bot_SendWelcome" targetRef="User_PressReportProgress"/>
    <bpmn:sequenceFlow id="Flow_05" sourceRef="User_PressReportProgress" targetRef="Bot_SendInputInstruction"/>
    <bpmn:sequenceFlow id="Flow_06" sourceRef="Bot_SendInputInstruction" targetRef="User_SendFreeText"/>
    <bpmn:sequenceFlow id="Flow_07" sourceRef="User_SendFreeText" targetRef="TG_ReceivePollingUpdate"/>
    <bpmn:sequenceFlow id="Flow_08" sourceRef="TG_ReceivePollingUpdate" targetRef="Bot_PreprocessText"/>

    <bpmn:sequenceFlow id="Flow_09" sourceRef="Bot_PreprocessText" targetRef="Bot_LoadDictionariesOnline"/>
    <bpmn:sequenceFlow id="Flow_10" sourceRef="Bot_LoadDictionariesOnline" targetRef="Bot_BuildPromptOnline"/>
    <bpmn:sequenceFlow id="Flow_11" sourceRef="Bot_BuildPromptOnline" targetRef="Bot_CallGeminiOnline"/>
    <bpmn:sequenceFlow id="Flow_12" sourceRef="Bot_CallGeminiOnline" targetRef="Gateway_OnlineLlmReplied"/>

    <bpmn:sequenceFlow id="Flow_13_yes" sourceRef="Gateway_OnlineLlmReplied" targetRef="Bot_ValidateJsonOnline" name="Success"/>
    <bpmn:sequenceFlow id="Flow_13_no" sourceRef="Gateway_OnlineLlmReplied" targetRef="Bot_CreateQueueTask" name="Timeout"/>
    <bpmn:sequenceFlow id="Flow_13_error" sourceRef="Gateway_OnlineLlmReplied" targetRef="Bot_SendProcessingError" name="Error"/>

    <bpmn:sequenceFlow id="Flow_14" sourceRef="Bot_ValidateJsonOnline" targetRef="Gateway_OnlineJsonValid"/>
    <bpmn:sequenceFlow id="Flow_15_yes" sourceRef="Gateway_OnlineJsonValid" targetRef="Bot_MapValidOnline" name="Yes"/>
    <bpmn:sequenceFlow id="Flow_15_no" sourceRef="Gateway_OnlineJsonValid" targetRef="Bot_MapFallbackOnline" name="No"/>
    <bpmn:sequenceFlow id="Flow_16a" sourceRef="Bot_MapValidOnline" targetRef="Sheets_WriteOnline"/>
    <bpmn:sequenceFlow id="Flow_16b" sourceRef="Bot_MapFallbackOnline" targetRef="Sheets_WriteOnline"/>
    <bpmn:sequenceFlow id="Flow_17" sourceRef="Sheets_WriteOnline" targetRef="Gateway_OnlineSheetsWriteSucceeded"/>
    <bpmn:sequenceFlow id="Flow_18_yes" sourceRef="Gateway_OnlineSheetsWriteSucceeded" targetRef="Bot_SendImmediateConfirmation" name="Yes"/>
    <bpmn:sequenceFlow id="Flow_18_no" sourceRef="Gateway_OnlineSheetsWriteSucceeded" targetRef="Bot_SendProcessingError" name="No"/>
    <bpmn:sequenceFlow id="Flow_19" sourceRef="Bot_SendImmediateConfirmation" targetRef="End_OnlineDone"/>

    <bpmn:sequenceFlow id="Flow_20" sourceRef="Bot_CreateQueueTask" targetRef="Bot_EnqueueMessage"/>
    <bpmn:sequenceFlow id="Flow_21" sourceRef="Bot_EnqueueMessage" targetRef="Gateway_EnqueueSucceeded"/>
    <bpmn:sequenceFlow id="Flow_22_yes" sourceRef="Gateway_EnqueueSucceeded" targetRef="Bot_SendQueuedNotice" name="Yes"/>
    <bpmn:sequenceFlow id="Flow_22_no" sourceRef="Gateway_EnqueueSucceeded" targetRef="Bot_SendProcessingError" name="No"/>
    <bpmn:sequenceFlow id="Flow_23" sourceRef="Bot_SendQueuedNotice" targetRef="End_OnlineQueued"/>

    <bpmn:sequenceFlow id="Flow_24" sourceRef="Queue_MessageReady" targetRef="Queue_PickPendingMessage"/>
    <bpmn:sequenceFlow id="Flow_25" sourceRef="Queue_PickPendingMessage" targetRef="Queue_LoadDictionaries"/>
    <bpmn:sequenceFlow id="Flow_26" sourceRef="Queue_LoadDictionaries" targetRef="Queue_BuildPrompt"/>
    <bpmn:sequenceFlow id="Flow_27" sourceRef="Queue_BuildPrompt" targetRef="Queue_CallGemini"/>
    <bpmn:sequenceFlow id="Flow_28" sourceRef="Queue_CallGemini" targetRef="Gateway_QueueLlmTimeout"/>

    <bpmn:sequenceFlow id="Flow_29_yes" sourceRef="Gateway_QueueLlmTimeout" targetRef="Queue_RequeueOnTimeout" name="Timeout"/>
    <bpmn:sequenceFlow id="Flow_29_no" sourceRef="Gateway_QueueLlmTimeout" targetRef="Queue_ValidateJson" name="Success"/>
    <bpmn:sequenceFlow id="Flow_29_error" sourceRef="Gateway_QueueLlmTimeout" targetRef="Queue_RequeueOnProcessingError" name="Error"/>
    <bpmn:sequenceFlow id="Flow_30" sourceRef="Queue_RequeueOnTimeout" targetRef="End_QueueDeferred"/>

    <bpmn:sequenceFlow id="Flow_31" sourceRef="Queue_ValidateJson" targetRef="Gateway_QueueJsonValid"/>
    <bpmn:sequenceFlow id="Flow_32_yes" sourceRef="Gateway_QueueJsonValid" targetRef="Queue_MapValid" name="Yes"/>
    <bpmn:sequenceFlow id="Flow_32_no" sourceRef="Gateway_QueueJsonValid" targetRef="Queue_MapFallback" name="No"/>
    <bpmn:sequenceFlow id="Flow_33a" sourceRef="Queue_MapValid" targetRef="Sheets_WriteQueue"/>
    <bpmn:sequenceFlow id="Flow_33b" sourceRef="Queue_MapFallback" targetRef="Sheets_WriteQueue"/>

    <bpmn:sequenceFlow id="Flow_34" sourceRef="Sheets_WriteQueue" targetRef="Gateway_QueueSheetsWriteSucceeded"/>
    <bpmn:sequenceFlow id="Flow_35_yes" sourceRef="Gateway_QueueSheetsWriteSucceeded" targetRef="Queue_MarkDone" name="Yes"/>
    <bpmn:sequenceFlow id="Flow_35_no" sourceRef="Gateway_QueueSheetsWriteSucceeded" targetRef="Queue_RequeueOnProcessingError" name="No"/>
    <bpmn:sequenceFlow id="Flow_36" sourceRef="Queue_MarkDone" targetRef="Bot_SendPostFactumNotification"/>
    <bpmn:sequenceFlow id="Flow_37" sourceRef="Bot_SendPostFactumNotification" targetRef="End_QueuedDone"/>
    <bpmn:sequenceFlow id="Flow_38" sourceRef="Queue_RequeueOnProcessingError" targetRef="End_QueueDeferred"/>

    <bpmn:sequenceFlow id="Flow_39" sourceRef="Bot_SendProcessingError" targetRef="End_OnlineFailed"/>

    <bpmn:textAnnotation id="TextAnnotation_LoggingAndNotes">
      <bpmn:text>Structured logging events reflected in this BPMN: polling_started, queue_worker_bootstrap_started, queue_worker_started, message_received, llm_response_received, llm_timeout, json_validation_passed/failed, queue_enqueued, queue_enqueue_failed, queue_dequeued, queue_task_invalid, queue_processing_failed, sheets_write_success/failed, post_factum_notification_sent, classification_failed, telegram_update_error. Online path ends immediately after queued notice; deferred processing and post-factum notification are executed by a separate polling queue worker process. Pilot queue mode intentionally runs without retry policy schedule/DLQ.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_LoggingAndNotes" sourceRef="End_QueuedDone" targetRef="TextAnnotation_LoggingAndNotes"/>
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_ConstructionReportBot">
    <bpmndi:BPMNPlane id="BPMNPlane_ConstructionReportBot" bpmnElement="Process_ConstructionReportBot">
      <bpmndi:BPMNShape id="Shape_Lane_User" bpmnElement="Lane_User" isHorizontal="true">
        <dc:Bounds x="120" y="100" width="5560" height="120"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Lane_Telegram" bpmnElement="Lane_Telegram" isHorizontal="true">
        <dc:Bounds x="120" y="220" width="5560" height="90"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Lane_Bot" bpmnElement="Lane_Bot" isHorizontal="true">
        <dc:Bounds x="120" y="310" width="5560" height="240"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Lane_QueueWorker" bpmnElement="Lane_QueueWorker" isHorizontal="true">
        <dc:Bounds x="120" y="550" width="5560" height="220"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Lane_Sheets" bpmnElement="Lane_Sheets" isHorizontal="true">
        <dc:Bounds x="120" y="770" width="5560" height="180"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_Start_UserOpensChat" bpmnElement="Start_UserOpensChat">
        <dc:Bounds x="160" y="142" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_User_OpenChat" bpmnElement="User_OpenChat">
        <dc:Bounds x="220" y="120" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_User_PressStart" bpmnElement="User_PressStart">
        <dc:Bounds x="380" y="120" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Bot_SendWelcome" bpmnElement="Bot_SendWelcome">
        <dc:Bounds x="540" y="390" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_User_PressReportProgress" bpmnElement="User_PressReportProgress">
        <dc:Bounds x="700" y="120" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Bot_SendInputInstruction" bpmnElement="Bot_SendInputInstruction">
        <dc:Bounds x="860" y="390" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_User_SendFreeText" bpmnElement="User_SendFreeText">
        <dc:Bounds x="1020" y="120" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_TG_ReceivePollingUpdate" bpmnElement="TG_ReceivePollingUpdate">
        <dc:Bounds x="1180" y="225" width="120" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_Bot_PreprocessText" bpmnElement="Bot_PreprocessText">
        <dc:Bounds x="1340" y="390" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Bot_LoadDictionariesOnline" bpmnElement="Bot_LoadDictionariesOnline">
        <dc:Bounds x="1500" y="390" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Bot_BuildPromptOnline" bpmnElement="Bot_BuildPromptOnline">
        <dc:Bounds x="1660" y="390" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Bot_CallGeminiOnline" bpmnElement="Bot_CallGeminiOnline">
        <dc:Bounds x="1820" y="390" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Gateway_OnlineLlmReplied" bpmnElement="Gateway_OnlineLlmReplied" isMarkerVisible="true">
        <dc:Bounds x="1980" y="405" width="50" height="50"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_Bot_ValidateJsonOnline" bpmnElement="Bot_ValidateJsonOnline">
        <dc:Bounds x="2100" y="390" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Gateway_OnlineJsonValid" bpmnElement="Gateway_OnlineJsonValid" isMarkerVisible="true">
        <dc:Bounds x="2260" y="405" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Bot_MapValidOnline" bpmnElement="Bot_MapValidOnline">
        <dc:Bounds x="2380" y="360" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Bot_MapFallbackOnline" bpmnElement="Bot_MapFallbackOnline">
        <dc:Bounds x="2380" y="470" width="120" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_Sheets_WriteOnline" bpmnElement="Sheets_WriteOnline">
        <dc:Bounds x="2560" y="820" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Gateway_OnlineSheetsWriteSucceeded" bpmnElement="Gateway_OnlineSheetsWriteSucceeded" isMarkerVisible="true">
        <dc:Bounds x="2740" y="835" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Bot_SendImmediateConfirmation" bpmnElement="Bot_SendImmediateConfirmation">
        <dc:Bounds x="2860" y="390" width="120" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_Bot_CreateQueueTask" bpmnElement="Bot_CreateQueueTask">
        <dc:Bounds x="2100" y="470" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Bot_EnqueueMessage" bpmnElement="Bot_EnqueueMessage">
        <dc:Bounds x="2260" y="470" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Gateway_EnqueueSucceeded" bpmnElement="Gateway_EnqueueSucceeded" isMarkerVisible="true">
        <dc:Bounds x="2420" y="485" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Bot_SendQueuedNotice" bpmnElement="Bot_SendQueuedNotice">
        <dc:Bounds x="2540" y="470" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Bot_SendProcessingError" bpmnElement="Bot_SendProcessingError">
        <dc:Bounds x="2860" y="500" width="120" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_Queue_MessageReady" bpmnElement="Queue_MessageReady">
        <dc:Bounds x="2700" y="642" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Queue_PickPendingMessage" bpmnElement="Queue_PickPendingMessage">
        <dc:Bounds x="2800" y="620" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Queue_LoadDictionaries" bpmnElement="Queue_LoadDictionaries">
        <dc:Bounds x="2960" y="620" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Queue_BuildPrompt" bpmnElement="Queue_BuildPrompt">
        <dc:Bounds x="3120" y="620" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Queue_CallGemini" bpmnElement="Queue_CallGemini">
        <dc:Bounds x="3280" y="620" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Gateway_QueueLlmTimeout" bpmnElement="Gateway_QueueLlmTimeout" isMarkerVisible="true">
        <dc:Bounds x="3440" y="635" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Queue_RequeueOnTimeout" bpmnElement="Queue_RequeueOnTimeout">
        <dc:Bounds x="3560" y="730" width="120" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_Queue_ValidateJson" bpmnElement="Queue_ValidateJson">
        <dc:Bounds x="3560" y="620" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Gateway_QueueJsonValid" bpmnElement="Gateway_QueueJsonValid" isMarkerVisible="true">
