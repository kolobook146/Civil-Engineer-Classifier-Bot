# Application
APP_ENV=dev
CLASSIFIER_VERSION=pilot-v1

# Telegram
TG_BOT_TOKEN=put_telegram_bot_token_here
TG_POLLING_TIMEOUT_SECONDS=30
TG_POLL_INTERVAL_SECONDS=1.0
TG_ALLOWED_UPDATES=message,callback_query

# Webhook (optional, for local dev via ngrok or any public HTTPS tunnel)
WEBHOOK_LISTEN_HOST=127.0.0.1
WEBHOOK_LISTEN_PORT=8080
WEBHOOK_PATH=telegram/webhook
WEBHOOK_PUBLIC_BASE_URL=
WEBHOOK_SECRET_TOKEN=
WEBHOOK_DROP_PENDING_UPDATES=true
WEBHOOK_MAX_CONNECTIONS=40

# LLM (native google-genai)
# Keep LLM_BASE_URL empty for the native Gemini SDK.
LLM_BASE_URL=
LLM_API_KEY=put_gemini_api_key_here
LLM_MODEL=gemini-2.5-flash
LLM_TIMEOUT_SECONDS=30

# Dictionaries
DICTIONARIES_DIR=dictionaries
WORK_TYPES_FILE=dictionaries/work_types.txt
STAGES_FILE=dictionaries/stages.txt
FUNCTIONS_FILE=dictionaries/functions.txt
UNITS_FILE=dictionaries/units.txt

# Google Sheets
GOOGLE_SERVICE_ACCOUNT_FILE=secrets/google-service-account.json
GOOGLE_SHEETS_SPREADSHEET_ID=put_google_sheets_spreadsheet_id_here
GOOGLE_SHEETS_WORKSHEET_NAME=data_facts

# Queue
QUEUE_DB_PATH=var/queue/queue.sqlite3
QUEUE_POLL_INTERVAL_SECONDS=5

# Logging
LOG_LEVEL=INFO
LOG_JSON=true
LOG_FILE_PATH=var/log/bot.log.jsonl
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
RAW_TEXT_PREVIEW_ENABLED=false
